# Copia este archivo a .env y rellena los valores. NUNCA subas .env a Git.
# .env está en .gitignore para que tus claves no se suban al repositorio.

# Obligatorios para que el bot funcione
DISCORD_TOKEN=tu_token_del_bot_aqui
DATABASE_URL=sqlite:///data/database.db

# Opcionales (servidor específico, admins, etc.)
# DISCORD_GUILD_ID=123456789
# ALLOWED_GUILD_IDS=123456789,987654321
# ADMIN_IDS=123456789,987654321

# Producción (PostgreSQL, Fly.io, etc.)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Challonge (torneos), imágenes, webhooks, etc. — ver config.py para más variables
